# ============================================================
#  amazing.build — environment variables
# ============================================================
#  Copy this file to .env and fill in values for local dev.
#  In Vercel: add these under Project Settings → Environment Variables.
#  NEVER commit .env with real values.
# ============================================================

# --- Airtable (waitlist + /source dashboard) ---
# 1. Go to https://airtable.com/create/tokens
# 2. Create a personal access token (NOT the legacy API key)
# 3. Grant scopes: data.records:read, data.records:write
# 4. Scope the token to your amazing.build base only.
AIRTABLE_API_KEY=

# Base ID — found in the URL: airtable.com/appXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=

# Table name exactly as it appears in Airtable (case-sensitive)
AIRTABLE_TABLE_NAME=Waitlist

# ============================================================
#  Required Airtable table schema (create these fields):
# ============================================================
#
#  Field name    | Type              | Notes
#  --------------|-------------------|-------------------------------
#  Email         | Email             | required, unique
#  Position      | Autonumber        | auto-assigned — read-only
#  ReferralId    | Single line text  | set server-side (7-char code)
#  ReferredBy    | Single line text  | record ID of referrer (or empty)
#  Source        | Single select     | options: direct, referral
#  CreatedAt     | Created time      | auto-assigned
#
#  Optional (for referral leaderboard later):
#  ReferralsCount | Number           | manually updated or via formula
#
# ============================================================
#  Airtable automation (set up in Airtable, not here):
# ============================================================
#  Trigger: "When a record is created" in Waitlist table
#  Action:  Send email (use Airtable's built-in email action)
#  Email content should match the receipt aesthetic —
#  use the same monospace/receipt voice as the site.
# ============================================================
